{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thumbnailer",
  "version": "0.3.2",
  "identifier": "dev.yun.thumbnailer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "thumbnailer",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 640,
        "backgroundColor": "#0b0c0f",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": []
  }
}
